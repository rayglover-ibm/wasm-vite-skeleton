{
  "name": "lib",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:native": "cmake --build build/native",
    "build": "pnpm build:native --config Release && vite build",
    "test": "vitest",
    "test:debug": "vitest --inspect-brk --test-timeout=600000 --no-file-parallelism",
    "prepare": "cmake-js --out build/native -G 'Ninja Multi-Config' --CDCMAKE_TOOLCHAIN_FILE=${EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake configure",
    "prepack": "pnpm build"
  },
  "exports": {
    ".": {
      "types": "./build/dts/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "imports": {
    "#wasi-lib.wasm": "./build/native/wasi-lib.wasm"
  },
  "devDependencies": {
    "cmake-js": "^8.0.0",
    "tinywasi": "git+https://github.com/rayglover-ibm/tinywasi.git#feat/environ",
    "typescript": "^5.9.3",
    "esbuild": "^0.27.4",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vite-plugin-dts": "^4.3.0"
  },
  "packageManager": "pnpm@9.12.3",
  "files": [
    "./dist",
    "./build/dts",
    "./package.json"
  ]
}
